<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>The Hymns Book</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="styles.css">
</head>
<body>

<header>
  <h1>The Hymns Book</h1>
  <button id="darkToggle">🌙</button>
</header>

<div class="container">
  
  <!-- Sidebar -->
  <aside class="sidebar">
    <input type="text" id="search" placeholder="Search hymns..." />
    <ul id="hymnList"></ul>
  </aside>

  <!-- Main Content -->
  <main class="content">
    <h2 id="title">Select a hymn</h2>
    <pre id="lyrics"></pre>
    <img id="chordImage" src="" alt="" />
  </main>

</div>

<!-- Lightbox -->
<div id="lightbox" class="lightbox">
  <img id="lightboxImg">
</div>

<script src="script.js"></script>
</body>
</html>
